# Puerto del servidor backend
PORT=3001

# URL de conexión a Redis
REDIS_URL=redis://localhost:6379

# URL del frontend (para configurar CORS)
FRONTEND_URL=http://localhost:5173

# Rate limiting
MAX_REQUESTS_PER_IP=5
RATE_LIMIT_WINDOW_MINUTES=15

# TTL de archivos temporales en minutos
DOWNLOAD_TTL_MINUTES=30

# Ruta al ejecutable de yt-dlp
# En Docker ya está instalado globalmente
# En desarrollo local: instalar con  pip install yt-dlp
YTDLP_PATH=yt-dlp
